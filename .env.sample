# dot.mindreset.tech credentials
QUOTE_API_KEY=dot_app_...
QUOTE_DEVICE_ID=XXXXXXXXXXXX

# Exactly two providers to render: claude, openai, kimi
USAGE_PROVIDERS=claude,openai

# Set to false to skip OpenAI Codex fetching (default: true)
# Only used when USAGE_PROVIDERS is unset.
# OPENAI_ENABLED=false

# Optional: override Codex OAuth token (default: read from ~/.codex/auth.json)
# CODEX_ACCESS_TOKEN=
# CODEX_ACCOUNT_ID=

# Optional: override Kimi Code auth/base URL (default: read from ~/.kimi/credentials/kimi-code.json)
# KIMI_CODE_ACCESS_TOKEN=
# KIMI_API_KEY=
# KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1

# Seconds between updates in --loop mode (default: 1800)
# UPDATE_INTERVAL=1800
